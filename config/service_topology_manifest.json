{
  "manifest_version": "phase-2-service-topology-v1",
  "services": [
    {
      "name": "signal-gateway",
      "port": 8000,
      "health_url": "http://127.0.0.1:8000/health",
      "service_root": "services\\signal-gateway",
      "process_match_patterns": [
        "services\\signal-gateway"
      ],
      "check_provider_status": false,
      "startup_name": "signal-gateway",
      "startup_workdir": "services\\signal-gateway",
      "startup_command": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8000"
    },
    {
      "name": "session-engine",
      "port": 8001,
      "health_url": "http://127.0.0.1:8001/health",
      "service_root": "services\\session-engine",
      "process_match_patterns": [
        "services\\session-engine"
      ],
      "check_provider_status": false,
      "startup_name": "session-engine",
      "startup_workdir": "services\\session-engine",
      "startup_command": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8001"
    },
    {
      "name": "herald-service",
      "port": 8002,
      "health_url": "http://127.0.0.1:8002/health",
      "service_root": "services\\herald-service",
      "process_match_patterns": [
        "services\\herald-service"
      ],
      "check_provider_status": false,
      "startup_name": "herald-service",
      "startup_workdir": "services\\herald-service",
      "startup_command": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8002"
    },
    {
      "name": "eidon-orchestrator",
      "port": 8003,
      "health_url": "http://127.0.0.1:8003/health",
      "service_root": "services\\eidon-orchestrator",
      "process_match_patterns": [
        "services\\eidon-orchestrator",
        "app.main:app"
      ],
      "check_provider_status": true,
      "startup_name": "eidon-orchestrator",
      "startup_workdir": "services\\eidon-orchestrator",
      "startup_command": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8003"
    }
  ]
}
