{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidonic.systems/schemas/signal-event.schema.json",
  "title": "SignalEvent",
  "description": "Raw typed ingress object for the Eidonic Core.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "signal_id",
    "signal_type",
    "source",
    "content",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "signal_id": {
      "type": "string",
      "description": "Unique ID for this signal event."
    },
    "signal_type": {
      "type": "string",
      "enum": [
        "user_message",
        "file_upload",
        "system_event",
        "command"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "chat",
        "upload",
        "internal",
        "api"
      ]
    },
    "content": {
      "type": "object",
      "description": "Primary signal payload."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "session_hint": {
      "type": "string",
      "description": "Optional session reference if one already exists."
    },
    "sensitivity_hint": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "unknown"
      ]
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata about ingress context."
    }
  }
}
