# Eidonic Core environment example
HERALD_BASE_URL=http://127.0.0.1:8001
SESSION_ENGINE_BASE_URL=http://127.0.0.1:8002
EIDON_BASE_URL=http://127.0.0.1:8003

# Session Engine backend selection
SESSION_ENGINE_STORE_BACKEND=postgres
SESSION_ENGINE_POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/eidonic_core

# Herald backend selection
HERALD_STORE_BACKEND=postgres
HERALD_POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/eidonic_core

# Signal Gateway backend selection
SIGNAL_GATEWAY_STORE_BACKEND=postgres
SIGNAL_GATEWAY_POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/eidonic_core

# Orchestrator backend selection
ORCHESTRATOR_STORE_BACKEND=postgres
ORCHESTRATOR_POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/eidonic_core
